<!-- Beacon type-specific control panel for probe overlay -->
<component>
  <view name="probe_beacon_panel"
        extends="lv_obj" width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255"
        style_radius="#border_radius" style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_md"
        scrollable="false">

    <text_small text="Beacon Controls" translation_tag="Beacon Controls" style_text_color="#text_muted"/>

    <!-- Sensor temperature readout -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_md"
            scrollable="false">
      <text_body text="Sensor Temperature" translation_tag="Sensor Temperature" flex_grow="1"/>
      <text_body bind_text="probe_beacon_temp" style_text_color="#text_accent"/>
    </lv_obj>

    <!-- Temperature compensation status -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_md"
            scrollable="false">
      <text_body text="Temp Compensation" translation_tag="Temp Compensation" flex_grow="1"/>
      <text_small bind_text="probe_beacon_temp_comp_status" style_text_color="#text_muted"/>
    </lv_obj>

    <!-- Action buttons -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" flex_wrap="wrap" style_pad_gap="#space_sm"
            scrollable="false">

      <!-- Calibrate -->
      <ui_button name="btn_beacon_calibrate"
                 width="48%" height="#button_height_sm" variant="outline" text="Calibrate" translation_tag="Calibrate"
                 icon="target">
        <event_cb trigger="clicked" callback="on_beacon_calibrate"/>
      </ui_button>

      <!-- Auto-Calibrate -->
      <ui_button name="btn_beacon_auto_cal"
                 width="48%" height="#button_height_sm" variant="outline" text="Auto Cal" translation_tag="Auto Cal"
                 icon="tune">
        <event_cb trigger="clicked" callback="on_beacon_auto_cal"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
