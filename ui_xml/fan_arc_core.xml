<!-- Fan Arc Core: Shared 270-degree arc visual with centered icon and speed label -->
<!-- Used by fan_dial, fan_status_card, and the fan carousel widget -->
<component>
  <api>
    <prop name="initial_value" type="number" default="0"/>
  </api>
  <view name="dial_container" extends="lv_obj"
        width="#fan_arc_size" height="#fan_arc_size"
        style_pad_all="0" style_pad_top="#space_sm" scrollable="false"
        style_flex_main_place="center" style_flex_cross_place="center"
        style_clip_content="false">
    <!-- 270-degree arc dial (size set dynamically by fan_arc_resize_to_fit) -->
    <lv_arc name="dial_arc"
            align="center"
            bg_start_angle="135" bg_end_angle="45"
            start_angle="135" end_angle="135"
            min_value="0" max_value="100" value="$initial_value"
            rotation="0" mode="normal"
            style_arc_color="#border"
            style_arc_color-indicator="#primary"
            style_arc_rounded="true" style_arc_rounded-indicator="true"
            style_bg_opa="0" style_border_width="0"/>
    <!-- Centered icon + percentage column -->
    <lv_obj name="center_content"
            align="center" width="content" height="content"
            style_pad_all="0" scrollable="false" flex_flow="column"
            style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_gap="0">
      <icon name="fan_icon" src="fan" size="sm" variant="secondary"/>
      <text_heading name="speed_label" text="Off" translation_tag="Off"/>
    </lv_obj>
  </view>
</component>
