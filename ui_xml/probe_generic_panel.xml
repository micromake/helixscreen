<!-- Generic/Klicky fallback panel for probe overlay -->
<component>
  <view name="probe_generic_panel"
        extends="lv_obj" width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255"
        style_radius="#border_radius" style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_md"
        scrollable="false">

    <text_small text="Probe Info" translation_tag="Probe Info" style_text_color="#text_muted"/>

    <!-- Probe details -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_md"
            scrollable="false">
      <text_body text="Type" translation_tag="Type" flex_grow="1"/>
      <text_body bind_text="probe_display_name" style_text_color="#text_accent"/>
    </lv_obj>

    <!-- Klicky dock controls (hidden unless Klicky type) -->
    <lv_obj name="klicky_controls" width="100%"
            height="content" style_pad_all="0" style_pad_top="#space_sm" flex_flow="row" flex_wrap="wrap"
            style_pad_gap="#space_sm" scrollable="false">
      <bind_flag_if_eq subject="probe_is_klicky" flag="hidden" ref_value="0"/>

      <text_small text="Klicky Controls" translation_tag="Klicky Controls" style_text_color="#text_muted"
                  width="100%"/>

      <!-- Deploy (Attach) -->
      <ui_button name="btn_klicky_deploy"
                 width="48%" height="#button_height_sm" variant="outline" text="Deploy" translation_tag="Deploy"
                 icon="arrow_down">
        <event_cb trigger="clicked" callback="on_klicky_deploy"/>
      </ui_button>

      <!-- Dock (Stow) -->
      <ui_button name="btn_klicky_dock"
                 width="48%" height="#button_height_sm" variant="outline" text="Dock" translation_tag="Dock"
                 icon="arrow_up">
        <event_cb trigger="clicked" callback="on_klicky_dock"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
