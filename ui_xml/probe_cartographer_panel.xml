<!-- Cartographer type-specific control panel for probe overlay -->
<component>
  <view name="probe_cartographer_panel"
        extends="lv_obj" width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255"
        style_radius="#border_radius" style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_md"
        scrollable="false">

    <text_small text="Cartographer Controls" translation_tag="Cartographer Controls" style_text_color="#text_muted"/>

    <!-- Coil temperature readout -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_md"
            scrollable="false">
      <text_body text="Coil Temperature" translation_tag="Coil Temperature" flex_grow="1"/>
      <text_body bind_text="probe_carto_coil_temp" style_text_color="#text_accent"/>
    </lv_obj>

    <!-- Action buttons -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" flex_wrap="wrap" style_pad_gap="#space_sm"
            scrollable="false">

      <!-- Calibrate -->
      <ui_button name="btn_carto_calibrate"
                 width="48%" height="#button_height_sm" variant="outline" text="Calibrate" translation_tag="Calibrate"
                 icon="target">
        <event_cb trigger="clicked" callback="on_carto_calibrate"/>
      </ui_button>

      <!-- Touch Calibrate -->
      <ui_button name="btn_carto_touch_cal"
                 width="48%" height="#button_height_sm" variant="outline" text="Touch Cal" translation_tag="Touch Cal"
                 icon="tune">
        <event_cb trigger="clicked" callback="on_carto_touch_cal"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
