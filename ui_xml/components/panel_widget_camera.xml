<component>
  <view name="panel_widget_camera" width="100%" height="100%"
        style_bg_color="#card_bg" style_bg_opa="cover" clip_corner="true"
        style_radius="#radius_md">
    <lv_image name="camera_image" width="100%" height="100%"
              style_image_recolor="#000000" style_image_recolor_opa="0"/>
    <lv_obj name="camera_overlay" align="center"
            width="content" height="content"
            style_pad_all="#space_lg"
            style_bg_opa="transp"
            flex_flow="column" flex_cross_place="center"
            style_layout="flex" style_flex_main_place="center"
            style_gap_row="#space_sm">
      <spinner name="camera_spinner" size="md"/>
      <text_body name="camera_status" width="100%"
                 style_text_color="#text_muted"
                 style_text_align="center"
                 bind_text="camera_status_text"/>
    </lv_obj>
  </view>
</component>
