<component>
  <view extends="lv_obj"
        width="100%" height="100%" style_pad_all="4" style_pad_gap="2"
        style_bg_opa="0%" scrollable="false" scrollbar_mode="off"
        flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
        >
    <event_cb trigger="clicked" callback="print_stats_clicked_cb"/>

    <!-- Title row (always visible) -->
    <lv_obj name="print_stats_title_row" width="100%" height="content"
            style_bg_opa="0%" style_pad_all="0" style_pad_gap="0"
            flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
            clickable="false" event_bubble="true">
      <text_small bind_text="print_stats_title"
                  style_text_color="#text_muted"
                  clickable="false" event_bubble="true"/>
    </lv_obj>

    <!-- Mode 0: narrow compact — time + success (2x1) -->
    <lv_obj name="print_stats_compact" width="100%" height="content"
            style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
            flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
            clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_stats_size_mode" flag="hidden" ref_value="0"/>
      <text_body bind_text="print_stats_total_time_short" clickable="false" event_bubble="true"/>
      <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
      <text_body bind_text="print_stats_success_rate" clickable="false" event_bubble="true"/>
    </lv_obj>

    <!-- Mode 3: wide compact — all stats inline (3x1+) -->
    <lv_obj name="print_stats_wide_compact" width="100%" height="content"
            style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
            flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
            clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_stats_size_mode" flag="hidden" ref_value="3"/>
      <text_body bind_text="print_stats_total_prints" clickable="false" event_bubble="true"/>
      <text_tiny text="prints" translation_tag="prints"
                 style_text_color="#text_muted" clickable="false" event_bubble="true"/>
      <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
      <text_body bind_text="print_stats_total_time_short" clickable="false" event_bubble="true"/>
      <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
      <text_body bind_text="print_stats_success_rate" clickable="false" event_bubble="true"/>
      <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
      <text_body bind_text="print_stats_weekly" clickable="false" event_bubble="true"/>
    </lv_obj>

    <!-- Mode 1: time+success top, details bottom (2x2) -->
    <lv_obj name="print_stats_grid" width="100%" height="content"
            style_bg_opa="0%" style_pad_all="0" style_pad_gap="2"
            flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
            clickable="false" event_bubble="true" scrollbar_mode="off">
      <bind_flag_if_not_eq subject="print_stats_size_mode" flag="hidden" ref_value="1"/>

      <!-- Top row: Time + Success -->
      <lv_obj width="100%" height="content" style_bg_opa="0%" style_pad_all="0" style_pad_gap="0"
              flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
              clickable="false" event_bubble="true">
        <!-- Time -->
        <lv_obj width="50%" height="content" style_bg_opa="0%" style_pad_all="1"
                flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
                clickable="false" event_bubble="true">
          <text_body bind_text="print_stats_total_time_short" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
          <text_tiny text="Time" translation_tag="Time"
                     style_text_color="#text_muted" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_obj>
        <!-- Success -->
        <lv_obj width="50%" height="content" style_bg_opa="0%" style_pad_all="1"
                flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
                clickable="false" event_bubble="true">
          <text_body bind_text="print_stats_success_rate" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
          <text_tiny text="Success" translation_tag="Success"
                     style_text_color="#text_muted" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_obj>
      </lv_obj>

      <!-- Bottom row: prints · hours · weekly -->
      <lv_obj width="100%" height="content" style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
              flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
              clickable="false" event_bubble="true">
        <text_body bind_text="print_stats_total_prints" clickable="false" event_bubble="true"/>
        <text_tiny text="prints" translation_tag="prints"
                   style_text_color="#text_muted" clickable="false" event_bubble="true"/>
        <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
        <text_body bind_text="print_stats_total_time_short" clickable="false" event_bubble="true"/>
        <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
        <text_body bind_text="print_stats_weekly" clickable="false" event_bubble="true"/>
      </lv_obj>
    </lv_obj>

    <!-- Mode 2: 3-col stats + activity line (3x2) -->
    <lv_obj name="print_stats_full" width="100%" height="content"
            style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
            flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
            clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_stats_size_mode" flag="hidden" ref_value="2"/>

      <!-- Top row: 3-col stats -->
      <lv_obj width="100%" height="content"
              style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
              flex_flow="row" style_flex_main_place="space_evenly" style_flex_cross_place="center"
              clickable="false" event_bubble="true">

        <!-- Total prints -->
        <lv_obj width="30%" height="content" style_bg_opa="0%" style_pad_all="#space_xs"
                flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
                clickable="false" event_bubble="true">
          <text_body bind_text="print_stats_total_prints" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
          <text_tiny text="Prints" translation_tag="Prints"
                     style_text_color="#text_muted" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_obj>

        <!-- Total time -->
        <lv_obj width="30%" height="content" style_bg_opa="0%" style_pad_all="#space_xs"
                flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
                clickable="false" event_bubble="true">
          <text_body bind_text="print_stats_total_time" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
          <text_tiny text="Time" translation_tag="Time"
                     style_text_color="#text_muted" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_obj>

        <!-- Success rate -->
        <lv_obj width="30%" height="content" style_bg_opa="0%" style_pad_all="#space_xs"
                flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
                clickable="false" event_bubble="true">
          <text_body bind_text="print_stats_success_rate" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
          <text_tiny text="Success" translation_tag="Success"
                     style_text_color="#text_muted" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_obj>
      </lv_obj>

      <!-- Bottom: activity line -->
      <lv_obj width="100%" height="content"
              style_bg_opa="0%" style_pad_all="0" style_pad_gap="#space_xs"
              flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
              clickable="false" event_bubble="true">
        <text_body bind_text="print_stats_weekly" style_text_color="#text_muted"
                   clickable="false" event_bubble="true"/>
        <text_tiny text="·" style_text_color="#text_muted" clickable="false" event_bubble="true"/>
        <text_body bind_text="print_stats_last_print" style_text_color="#text_muted"
                   clickable="false" event_bubble="true"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
