<component>
  <view name="panel_widget_bed_temperature" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0"
        style_pad_left="#space_xxs" style_pad_right="#space_xxs" scrollable="false">
    <ui_button name="bed_temp_btn"
               width="100%" height="100%" variant="ghost" flex_flow="column" style_flex_main_place="center"
               style_flex_cross_place="center" style_flex_track_place="center" style_border_width="0"
               focusable="false">
      <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>
      <event_cb trigger="clicked" callback="bed_temp_clicked_cb"/>
      <icon name="bed_icon_glyph" src="radiator" size="#icon_size" variant="secondary"
            clickable="false" event_bubble="true"/>
      <temp_display name="bed_temp_text_label"
                    size="sm" show_target="false" bind_current="bed_temp"
                    bind_target="bed_target" align="center"/>
    </ui_button>
  </view>
</component>
