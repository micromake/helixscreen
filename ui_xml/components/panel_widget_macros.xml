<component>
  <view name="panel_widget_macros" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0" scrollable="false">
    <ui_button name="macros_button"
               width="100%" height="100%" variant="ghost" style_border_width="0" focusable="false">
      <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>
