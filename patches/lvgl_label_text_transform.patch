diff --git a/src/widgets/label/lv_label.c b/src/widgets/label/lv_label.c
index d550043c5..8b00b7db2 100644
--- a/src/widgets/label/lv_label.c
+++ b/src/widgets/label/lv_label.c
@@ -170,6 +170,14 @@ void lv_label_set_text_vfmt(lv_obj_t * obj, const char * fmt, va_list args)
     lv_label_mark_need_refr_text(obj);
 }
 
+void lv_label_set_text_transform_upper(lv_obj_t * obj, bool enable)
+{
+    LV_ASSERT_OBJ(obj, MY_CLASS);
+    lv_label_t * label = (lv_label_t *)obj;
+    label->text_transform_upper = enable ? 1 : 0;
+    if(enable) set_text_internal(obj, NULL); /* Re-process current text */
+}
+
 void lv_label_set_text_static(lv_obj_t * obj, const char * text)
 {
     LV_ASSERT_OBJ(obj, MY_CLASS);
@@ -1016,6 +1024,41 @@ static void set_text_internal(lv_obj_t * obj, const char * text)
         label->static_txt = 0;
     }
 
+    /* HelixScreen extension: uppercase transform before layout measurement.
+     * Handles ASCII a-z and Latin-1 Supplement (U+00E0-U+00FE) encoded as UTF-8.
+     * Scripts without case (CJK, Arabic, Thai, etc.) pass through unchanged. */
+    if(label->text_transform_upper && label->text) {
+        uint8_t * p = (uint8_t *)label->text;
+        while(*p) {
+            if(*p >= 'a' && *p <= 'z') {
+                /* ASCII lowercase в†’ uppercase */
+                *p -= 32;
+                p++;
+            }
+            else if(p[0] == 0xC3 && p[1] >= 0xA0 && p[1] <= 0xBE && p[1] != 0xB7) {
+                /* UTF-8 Latin-1 Supplement lowercase (U+00E0-U+00FE, except U+00F7 Г·)
+                 * e.g., Г в†’ГЂ, Г©в†’Г‰, Г±в†’Г‘, Гјв†’Гњ. Same byte length, just subtract 0x20. */
+                p[1] -= 0x20;
+                p += 2;
+            }
+            else if(*p < 0x80) {
+                p++;           /* ASCII non-alpha */
+            }
+            else if(*p < 0xC0) {
+                p++;           /* continuation byte (shouldn't happen at start) */
+            }
+            else if(*p < 0xE0) {
+                p += 2;        /* 2-byte UTF-8 sequence (other) */
+            }
+            else if(*p < 0xF0) {
+                p += 3;        /* 3-byte UTF-8 sequence */
+            }
+            else {
+                p += 4;        /* 4-byte UTF-8 sequence */
+            }
+        }
+    }
+
     lv_label_mark_need_refr_text(obj);
 }
 
